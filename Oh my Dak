let currentReview = 0;
const reviewCards = document.querySelectorAll('.review-card');
const reviewDots = document.querySelectorAll('.review-dot');
function showReview(i) {
  reviewCards.forEach((c,j) => c.classList.toggle('active', i===j));
  reviewDots.forEach((d,j) => d.classList.toggle('active', i===j));
  currentReview = i;
}
setInterval(() => showReview((currentReview+1) % reviewCards.length), 4000);

const overlay = document.getElementById('transition-overlay');
function openCategory(key) {
  overlay.classList.add('active');
  setTimeout(() => {
    buildCategoryPage(key);
    document.getElementById('page-home').classList.remove('active');
    document.getElementById('page-category').classList.add('active');
    window.scrollTo(0,0);
    overlay.classList.remove('active');
    animateItems();
  }, 300);
}
function goHome() {
  overlay.classList.add('active');
  setTimeout(() => {
    document.getElementById('page-category').classList.remove('active');
    document.getElementById('page-home').classList.add('active');
    window.scrollTo(0,0);
    overlay.classList.remove('active');
  }, 300);
}
function buildCategoryPage(key) {
  const cat = categories[key];
  document.getElementById('cat-hero-img').src = cat.img;
  document.getElementById('cat-page-title').textContent = cat.name;
  document.getElementById('cat-page-sub').textContent = cat.sub;
  const container = document.getElementById('items-container');
  container.innerHTML = '';
  cat.items.forEach((item,i) => {
    if (item.type === 'header') {
      const h = document.createElement('div');
      h.className = 'sub-header';
      h.textContent = item.label;
      container.appendChild(h);
      return;
    }
    const el = document.createElement('div');
    el.className = 'menu-item';
    el.style.transitionDelay = `${i*0.04}s`;
    el.innerHTML = `
      <div class="item-header">
        <div class="item-name">${item.name}</div>
        <div class="item-price">${item.price}</div>
      </div>
      ${item.desc ? `<div class="item-desc">${item.desc}</div>` : ''}
      ${item.tags.length ? `<div class="item-tags">${item.tags.map(t=>`<span class="tag ${t==='Popular'||t==='Fan Favorite'?'popular':t==='Hot'||t==='Spicy'?'hot':''}">${t}</span>`).join('')}</div>` : ''}
    `;
    container.appendChild(el);
  });
}
function animateItems() {
  setTimeout(() => {
    const items = document.querySelectorAll('.menu-item');
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
    }, {threshold:0.1});
    items.forEach(item => obs.observe(item));
  }, 100);
}
