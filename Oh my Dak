<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Oh My Dak — Menu</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Cormorant+Garamond:wght@300;400;500&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --gold: #C9A84C;
  --gold-light: #E8C97A;
  --gold-dim: #8B6914;
  --black: #0A0A0A;
  --dark: #0D0A03;
  --card-bg: #130F05;
  --text: #F0E6C8;
  --text-dim: #9A8A6A;
  --border: rgba(201,168,76,0.25);
}
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body { background:var(--dark); color:var(--text); font-family:'Montserrat',sans-serif; overflow-x:hidden; }
.page { display:none; min-height:100vh; }
.page.active { display:block; }

/* ── HERO ── */
.hero-section {
  position:relative;
  min-height:100vh;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  overflow:hidden;
}
.hero-bg {
  position:absolute;
  inset:0;
  background-image:var(--store-img);
  background-size:cover;
  background-position:center 30%;
  filter:brightness(0.35) saturate(0.7);
  transform:scale(1.05);
  animation:slowZoom 20s ease infinite alternate;
}
@keyframes slowZoom {
  from { transform:scale(1.05); }
  to   { transform:scale(1.12); }
}
.hero-gradient {
  position:absolute;
  inset:0;
  background: linear-gradient(
    to bottom,
    rgba(13,10,3,0.2) 0%,
    rgba(13,10,3,0.1) 30%,
    rgba(13,10,3,0.7) 65%,
    rgba(13,10,3,0.98) 100%
  );
}
.hero-content {
  position:relative;
  z-index:2;
  padding:40px 24px 36px;
  text-align:center;
}
.hero-badge {
  display:inline-block;
  font-size:9px;
  font-weight:600;
  letter-spacing:4px;
  text-transform:uppercase;
  color:var(--gold);
  border:1px solid var(--border);
  padding:5px 16px;
  margin-bottom:18px;
  animation:fadeUp 0.8s ease both;
}
.hero-title {
  font-family:'Playfair Display',serif;
  font-size:clamp(48px,14vw,80px);
  font-weight:900;
  color:var(--gold);
  line-height:0.95;
  text-shadow:0 0 80px rgba(201,168,76,0.4);
  animation:fadeUp 0.9s ease 0.1s both;
}
.hero-title span {
  display:block;
  font-size:clamp(11px,3vw,16px);
  font-weight:300;
  letter-spacing:5px;
  color:var(--text-dim);
  font-family:'Cormorant Garamond',serif;
  font-style:italic;
  margin-top:10px;
}
.hero-line {
  width:60px; height:1px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
  margin:22px auto;
  animation:fadeUp 1s ease 0.2s both;
}
.hero-tagline {
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(17px,5vw,22px);
  font-style:italic;
  color:var(--text);
  line-height:1.5;
  animation:fadeUp 1s ease 0.3s both;
}
.hero-sub {
  font-size:10px;
  letter-spacing:3px;
  color:var(--text-dim);
  text-transform:uppercase;
  margin-top:8px;
  animation:fadeUp 1s ease 0.4s both;
}

/* ── CATEGORIES ── */
.section-label {
  text-align:center;
  font-size:9px;
  letter-spacing:4px;
  text-transform:uppercase;
  color:var(--gold-dim);
  padding:32px 0 16px;
  position:relative; z-index:1;
}
.categories-grid {
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:12px;
  padding:0 14px 36px;
  position:relative; z-index:1;
}
.cat-card {
  position:relative;
  border-radius:3px;
  overflow:hidden;
  border:1px solid var(--border);
  cursor:pointer;
  background:var(--card-bg);
  transition:transform 0.3s ease, border-color 0.3s ease;
  animation:fadeUp 0.8s ease calc(0.5s + var(--i)*0.07s) both;
}
.cat-card:active { transform:scale(0.97); }
.cat-card:hover { border-color:var(--gold); transform:translateY(-2px); }
.cat-img {
  width:100%; height:108px;
  object-fit:cover; display:block;
  filter:brightness(0.55) sepia(0.25);
  transition:filter 0.4s ease, transform 0.4s ease;
}
.cat-card:hover .cat-img { filter:brightness(0.75) sepia(0.1); transform:scale(1.04); }
.cat-overlay {
  position:absolute; inset:0;
  background:linear-gradient(to top, rgba(10,8,2,0.96) 0%, rgba(10,8,2,0.2) 60%, transparent 100%);
}
.cat-info { position:absolute; bottom:0; left:0; right:0; padding:10px 12px; }
.cat-name {
  font-family:'Playfair Display',serif;
  font-size:13px; font-weight:700;
  color:var(--gold-light); line-height:1.2;
}
.cat-count { font-size:9px; letter-spacing:2px; color:var(--text-dim); text-transform:uppercase; margin-top:2px; }
.cat-arrow {
  position:absolute; top:9px; right:9px;
  width:20px; height:20px;
  border:1px solid rgba(201,168,76,0.35);
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:10px; color:var(--gold);
}
.full-width { grid-column:1 / -1; }
.full-width .cat-img { height:88px; }

/* ── REVIEWS ── */
.reviews-section { padding:10px 16px 50px; }
.reviews-label {
  text-align:center; font-size:9px; letter-spacing:4px;
  text-transform:uppercase; color:var(--gold-dim); margin-bottom:18px;
}
.reviews-carousel { position:relative; overflow:hidden; min-height:130px; }
.review-card {
  position:absolute; inset:0;
  background:var(--card-bg);
  border:1px solid var(--border);
  border-radius:3px;
  padding:18px;
  opacity:0; transform:translateY(16px);
  transition:opacity 0.6s ease, transform 0.6s ease;
  pointer-events:none;
}
.review-card.active { opacity:1; transform:translateY(0); pointer-events:auto; }
.review-stars { color:var(--gold); font-size:12px; letter-spacing:2px; margin-bottom:9px; }
.review-text {
  font-family:'Cormorant Garamond',serif;
  font-size:15px; font-style:italic;
  color:var(--text); line-height:1.5; margin-bottom:10px;
}
.review-author { font-size:9px; letter-spacing:2px; text-transform:uppercase; color:var(--gold-dim); }
.review-dots { display:flex; justify-content:center; gap:6px; margin-top:14px; }
.review-dot {
  width:5px; height:5px; border-radius:50%;
  background:var(--gold-dim);
  transition:background 0.3s, transform 0.3s;
}
.review-dot.active { background:var(--gold); transform:scale(1.3); }
.home-footer {
  text-align:center; padding:0 0 28px;
  font-size:9px; letter-spacing:2px;
  color:var(--gold-dim); text-transform:uppercase;
}

/* ── CATEGORY PAGE ── */
#page-category { background:var(--dark); }
.cat-hero {
  position:relative; height:230px; overflow:hidden;
}
.cat-hero-img {
  width:100%; height:100%; object-fit:cover;
  filter:brightness(0.45) sepia(0.35);
  transform:scale(1.04);
}
.cat-hero-overlay {
  position:absolute; inset:0;
  background:linear-gradient(to bottom, rgba(13,10,3,0.25) 0%, rgba(13,10,3,0.97) 100%);
}
.cat-hero-content {
  position:absolute; bottom:22px; left:22px; right:22px;
}
.back-btn {
  display:inline-flex; align-items:center; gap:6px;
  font-size:9px; letter-spacing:3px; text-transform:uppercase;
  color:var(--gold-dim); cursor:pointer;
  margin-bottom:14px; padding:6px 0;
  transition:color 0.3s; border:none; background:none;
}
.back-btn:hover { color:var(--gold); }
.cat-page-title {
  font-family:'Playfair Display',serif;
  font-size:clamp(26px,7vw,38px);
  font-weight:900; color:var(--gold); line-height:1;
}
.cat-page-sub {
  font-family:'Cormorant Garamond',serif;
  font-size:13px; font-style:italic;
  color:var(--text-dim); margin-top:4px;
}
.items-container { padding:6px 16px 60px; }
.menu-item {
  border-bottom:1px solid rgba(201,168,76,0.1);
  padding:18px 0;
  opacity:0; transform:translateX(-18px);
  transition:opacity 0.5s ease, transform 0.5s ease;
}
.menu-item.visible { opacity:1; transform:translateX(0); }
.item-header { display:flex; justify-content:space-between; align-items:flex-start; gap:12px; margin-bottom:5px; }
.item-name {
  font-family:'Playfair Display',serif;
  font-size:15px; font-weight:700;
  color:var(--text); line-height:1.2; flex:1;
}
.item-price {
  font-family:'Cormorant Garamond',serif;
  font-size:17px; font-weight:500;
  color:var(--gold); white-space:nowrap; flex-shrink:0;
}
.item-desc { font-size:11px; color:var(--text-dim); line-height:1.6; margin-bottom:7px; }
.item-tags { display:flex; flex-wrap:wrap; gap:4px; }
.tag {
  font-size:9px; letter-spacing:1.5px; text-transform:uppercase;
  color:var(--gold-dim); border:1px solid rgba(201,168,76,0.2);
  padding:2px 7px; border-radius:2px;
}
.tag.hot { color:#E8704A; border-color:rgba(232,112,74,0.3); }
.tag.popular { color:var(--gold); border-color:rgba(201,168,76,0.4); }
.sub-header {
  font-size:9px; letter-spacing:4px; text-transform:uppercase;
  color:var(--gold); padding:22px 0 7px;
  border-bottom:1px solid var(--border); margin-bottom:3px;
}

/* ── TRANSITION ── */
#transition-overlay {
  position:fixed; inset:0; background:var(--black);
  z-index:999; pointer-events:none; opacity:0;
  transition:opacity 0.3s ease;
}
#transition-overlay.active { opacity:1; pointer-events:all; }

@keyframes fadeUp {
  from { opacity:0; transform:translateY(22px); }
  to   { opacity:1; transform:translateY(0); }
}
</style>
</head>
